---
interface Props {
  recipe: any;
  index: number;
}

const { recipe, index } = Astro.props;
---

<a href={`${import.meta.env.BASE_URL}/recipes/${recipe.id}`} class="card" style={`--i: ${index}`} data-category={recipe.data.category}>
  <div class="card-image">
    {recipe.data.image ? (
      <img src={recipe.data.image} alt={recipe.data.title} />
    ) : (
      <div class="card-placeholder">
        <span class="icon">+</span>
        <span class="text">Add photo</span>
      </div>
    )}
    {recipe.data.favorite && <span class="favorite-badge">&#9733;</span>}
  </div>
  <div class="card-content">
    <h3 class="card-title">{recipe.data.title}</h3>
    <p class="card-description">{recipe.data.description}</p>
    <div class="card-meta">
      <span class="cook-time">{recipe.data.cookTime > 0 ? `${recipe.data.prepTime + recipe.data.cookTime} min` : 'No cook'}</span>
      <div class="tags">
        {recipe.data.tags.slice(0, 2).map((tag: string) => <span class="tag">{tag}</span>)}
      </div>
    </div>
  </div>
</a>

<style>
  .card {
    background: var(--color-warm-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: block;
    text-decoration: none;
    color: inherit;
    opacity: 0;
    animation: cardEntrance 0.5s ease forwards;
    animation-delay: calc(var(--i, 0) * 0.1s);
  }

  .card:hover {
    transform: translateY(-4px) rotate(-0.5deg);
    box-shadow: var(--shadow-lifted);
  }

  .card:nth-child(even) {
    background: var(--color-linen);
  }

  .card-image {
    position: relative;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .card-placeholder {
    aspect-ratio: 4/3;
    width: 100%;
    background: linear-gradient(135deg, var(--color-sage-light) 0%, var(--color-sage) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    color: white;
  }

  .card-placeholder .icon {
    font-size: 1.5rem;
    width: 40px;
    height: 40px;
    border: 2px dashed rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-placeholder .text {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .favorite-badge {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    background: var(--color-terracotta);
    color: white;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
  }

  .card-content {
    padding: var(--space-md);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-charcoal);
    margin-bottom: var(--space-xs);
  }

  .card-description {
    font-size: 0.875rem;
    color: #666;
    margin-bottom: var(--space-sm);
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    display: -webkit-box;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.75rem;
  }

  .cook-time {
    color: var(--color-terracotta);
    font-weight: 600;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    background: var(--color-butter);
    color: var(--color-charcoal);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
  }
</style>
